      <article className='Medias'>\n            <div class=\"image_wrap\">\n                <div onClick={handleClick} className=\"Bookmark\">\n                    <img  src={BookMark} alt=\"bookmark\"/>\n                </div>\n                <img src={Image} alt=\"movie image\" className=\"thumbnail\" />\n            </div>\n            <div className=\"Movie_detail\">\n                <div className=\"sub_caption\">\n                    <p>{Caption.year}</p>\n                    {Category}\n                    <p>{Caption.rating}</p>\n                </div>\n                <p className=\"Title\">{Title}</p>\n            </div>\n        </article>\n    )\n}","/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/Registrations.js",["115","116"],[],"import { RegisterCard, SignIn } from \"./RegisterCard\";\nimport Logo from '../assets/logo.svg'\nimport Input from \"../Components/Input\";\nexport default function Registrations() {\n    let signUpCard = (\n        <RegisterCard\n                PageName={\"Sign up\"}\n                Button={\n                    {\n                        className: \"signUp_btn\",\n                        text: \"Create an account\",\n\n                    }\n                }\n                Alternative={\n                    {\n                        text:\"Already have an account?\",\n                        className: \"reg_signUp\",\n                        redirect: \"Login\"\n                    }\n                }\n\n            >\n                <Input\n                    Label={\"Email address\"}\n                    attribute={{id:\"Email\", class:\"Email_input\"}}\n                    type={\"email\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Email address\"}\n                />\n                <Input\n                    Label={\"Password\"}\n                    attribute={{id:\"Password\", class:\"Pass_input\"}}\n                    type={\"password\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Password\"}\n                />\n                <Input\n                    Label={\"Repeat password\"}\n                    attribute={{id:\"Repeat_password\", class:\"RepeatPass_input\"}}\n                    type={\"password\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Repeat password\"}\n                />\n            </RegisterCard>    \n    )\n    let signInCard = (\n        <RegisterCard\n                PageName={\"Login\"}\n                Button={\n                    {\n                        className: \"login_btn\",\n                        text: \"Login into your account\",\n\n                    }\n                }\n                Alternative={\n                    {\n                        text:\"Don't have an account?\",\n                        className: \"reg_signIn\",\n                        redirect: \"Sign up\"\n                    }\n                }\n\n            >\n                <Input\n                    Label={\"Email address\"}\n                    attribute={{id:\"Email\", class:\"Email_input\"}}\n                    type={\"email\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Email address\"}\n                />\n                <Input\n                    Label={\"Password\"}\n                    attribute={{id:\"Password\", class:\"Pass_input\"}}\n                    type={\"password\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Password\"}\n                />\n            </RegisterCard>  \n    )\n    return (\n        <section id=\"Register\">\n            <img src={Logo} alt=\"Logo\" />\n               {signInCard}\n                   \n        </section>\n    )\n}","/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/Input.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/RegisterCard.js",["117"],[],"import Input from \"../Components/Input\"\nexport function RegisterCard({children,PageName, submitForm, handleChange,value, Button, Alternative}) {\n    return(\n        <div className=\"register_form signin\">\n            <h1>{PageName}</h1>\n            <form id=\"SignIn\" action=\"\">\n                {children}\n                <button className={`reg_btn ${Button.className}_btn`} onClick={submitForm}>{Button.text}</button>\n                <p>{Alternative.text} <span className={`reg_nav ${Alternative.className}` }>{Alternative.redirect}</span></p>\n            </form>\n        </div>\n    )\n}","/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/Nav.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/searchBar.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/TrendingMedia.js",["118"],[],"import BookMark from '../assets/icon-bookmark-empty.svg'\nimport sampleImage from '../assets/thumbnails/beyond-earth/trending/large.jpg'\nexport default function TrendingMedia({Image, TrendingClass, altText, Title, Caption}) {\n    const posterStyle = {\n        backgroundImage: `url(${Image})`,\n        backgroundSize: \"cover\",\n\n    }\n    return (\n        <article style={posterStyle} className={`TrendingMedia ${TrendingClass}`}>\n            <div class=\"img_wrap\">\n                <div className=\"Bookmark\">\n                    <img src={BookMark} alt=\"bookmark\"/>\n                </div>\n                <div className=\"Captions\">\n                    <div className='sub_caption'>\n                        <p>{Caption.year}</p>\n                        <p className=\"sub_type\">\n                            <span className=\"type_icon\">{Caption.icon}</span>\n                            {Caption.cate}\n                        </p>\n                        <p>{Caption.rating}</p>\n                    </div>\n                    <p className='Trending_title'>{Title}</p>\n                </div>\n                {/* <img src={Image} alt={altText} className=\"thumbnail\" /> */}\n            </div>\n        </article>\n    )\n}","/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/Movie.js",["119","120","121"],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/Signup.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/BookedMark.js",["122","123","124","125","126","127"],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/Dashboard.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/TvMovies.js",["128"],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/MediaComponents.js",["129"],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/BookmarkContext.js",[],[],{"ruleId":"130","severity":1,"message":"131","line":1,"column":8,"nodeType":"132","messageId":"133","endLine":1,"endColumn":12},{"ruleId":"130","severity":1,"message":"134","line":5,"column":8,"nodeType":"132","messageId":"133","endLine":5,"endColumn":21},{"ruleId":"130","severity":1,"message":"135","line":11,"column":10,"nodeType":"132","messageId":"133","endLine":11,"endColumn":23},{"ruleId":"130","severity":1,"message":