         attribute={{id:\"Email\", class:\"Email_input\"}}\n                    type={\"email\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Email address\"}\n                />\n                <Input\n                    Label={\"Password\"}\n                    attribute={{id:\"Password\", class:\"Pass_input\"}}\n                    type={\"password\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Password\"}\n                />\n                <Input\n                    Label={\"Repeat password\"}\n                    attribute={{id:\"Repeat_password\", class:\"RepeatPass_input\"}}\n                    type={\"password\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Repeat password\"}\n                />\n            </RegisterCard>    \n    )\n    let signInCard = (\n        <RegisterCard\n                PageName={\"Login\"}\n                Button={\n                    {\n                        className: \"login_btn\",\n                        text: \"Login into your account\",\n\n                    }\n                }\n                Alternative={\n                    {\n                        text:\"Don't have an account?\",\n                        className: \"reg_signIn\",\n                        redirect: \"Sign up\"\n                    }\n                }\n\n            >\n                <Input\n                    Label={\"Email address\"}\n                    attribute={{id:\"Email\", class:\"Email_input\"}}\n                    type={\"email\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Email address\"}\n                />\n                <Input\n                    Label={\"Password\"}\n                    attribute={{id:\"Password\", class:\"Pass_input\"}}\n                    type={\"password\"}\n                    // handleChange={handleChange}\n                    // value={value}\n                    Placeholder={\"Password\"}\n                />\n            </RegisterCard>  \n    )\n    return (\n        <section id=\"Register\">\n            <img src={Logo} alt=\"Logo\" />\n               {signInCard}\n                   \n        </section>\n    )\n}","/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/Input.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/RegisterCard.js",["103"],[],"import Input from \"../Components/Input\"\nexport function RegisterCard({children,PageName, submitForm, handleChange,value, Button, Alternative}) {\n    return(\n        <div className=\"register_form signin\">\n            <h1>{PageName}</h1>\n            <form id=\"SignIn\" action=\"\">\n                {children}\n                <button className={`reg_btn ${Button.className}_btn`} onClick={submitForm}>{Button.text}</button>\n                <p>{Alternative.text} <span className={`reg_nav ${Alternative.className}` }>{Alternative.redirect}</span></p>\n            </form>\n        </div>\n    )\n}","/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/Nav.js",["104","105","106","107"],[],"import Home from \"../assets/icon-nav-home.svg\"\nimport Bookmark from \"../assets/icon-nav-bookmark.svg\"\nimport Movie from \"../assets/icon-nav-movies.svg\"\nimport TV from \"../assets/icon-nav-tv-series.svg\"\nimport Logo from '../assets/logo.svg'\nexport default function Nav() {\n    return (\n        <header id=\"Header\">\n            <img src={Logo} alt=\"Logo\" />\n            <nav id=\"Nav\">\n                <ul className=\"Links\">\n                    <li className=\"link\">\n                        <a>\n                            <img src={Home} alt=\"\" />\n                        </a>\n                    </li>\n                    <li className=\"link\">\n                        <a>\n                            <img src={Movie} alt=\"\" />\n                        </a>\n                    </li>\n                    <li className=\"link\">\n                        <a>\n                            <img src={TV} alt=\"\" />\n                        </a>\n                    </li>\n                    <li className=\"link\">\n                        <a>\n                            <img src={Bookmark} alt=\"\" />\n                        </a>\n                    </li>\n                </ul>\n            </nav>\n            <div id=\"UserProfile\">\n                \n            </div>\n        </header>\n    )\n}","/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/searchBar.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Components/TrendingMedia.js",["108"],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/Movie.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/Signup.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/BookedMark.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/Dashboard.js",[],[],"/Users/patleo/Desktop/Dropbox/Porfolio/Frontends/React/entertainment-web-app/entertainment-app/src/Pages/TvMovies.js",["109"],[],{"ruleId":"110","severity":1,"message":"111","line":1,"column":8,"nodeType":"112","messageId":"113","endLine":1,"endColumn":12},{"ruleId":"110","severity":1,"message":"114","line":4,"column":8,"nodeType":"112","messageId":"113","endLine":4,"endColumn":21},{"ruleId":"110","s